# Public site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === Auth (Clerk) — wired in next iteration, ADR-0011 step 2 ===
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# === Database (Postgres via Drizzle) — wired in next iteration ===
DATABASE_URL=postgresql://user:password@localhost:5432/mrt_dev

# === Storage (R2 / S3 per ADR-0003) — uploads + audio recording (V1.21.0) ===
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# === Realtime (Liveblocks) — adapter stub only in MVP per ADR-0011 ===
LIVEBLOCKS_SECRET_KEY=

# === Background jobs (Inngest) — V1.5; keyless against `npx inngest-cli dev` locally ===
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# === Rate limiting (Upstash Redis) — V1.7.0 deploy, ADR-0016 / security review #9 ===
# Leave blank locally: the limiter falls back to an in-memory per-instance
# counter in dev/test (in production these are REQUIRED — a missing value is a
# fatal error, not a silent no-op). UPSTASH_IP_BUCKET_SALT salts the one-way
# coarse-IP hash used only as a limiter key (never persisted).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
UPSTASH_IP_BUCKET_SALT=

# === Secret encryption (V1.5, ADR-0005) — registry OAuth tokens at rest ===
# Base64-encoded 32-byte key, e.g. `openssl rand -base64 32`
TOKEN_ENCRYPTION_KEY=

# === OSF registry (V1.5, ADR-0005) — register an app at osf.io/settings/applications ===
# OSF_OAUTH_REDIRECT_URI must EXACTLY match the redirect registered on the OSF app
# AND the running host:port. Authorize/token URLs default to OSF's documented
# values; override if your app differs.
OSF_OAUTH_CLIENT_ID=
OSF_OAUTH_CLIENT_SECRET=
OSF_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/osf/callback
OSF_API_BASE=https://api.osf.io/v2
OSF_AUTHORIZE_URL=https://accounts.osf.io/oauth2/authorize
OSF_TOKEN_URL=https://accounts.osf.io/oauth2/token
OSF_SCOPES=osf.full_write

# === Prolific recruitment (V1.15, ADR-0047) ===
# PAT-first: each researcher pastes their own Personal Access Token in
# Participants · Connections (stored encrypted; NOT an env var). These are
# global, optional knobs only:
# PROLIFIC_API_BASE overrides the API root (default https://api.prolific.com/api/v1).
PROLIFIC_API_BASE=https://api.prolific.com/api/v1
# Webhooks ("live updates", ADR-0050) need NO env var: the signing secret is
# per-workspace, created via Prolific's API and stored encrypted when a researcher
# clicks "Enable live updates" in Participants · Connections. Without it,
# recruitment state still refreshes on load + via the 10-min polling sweep.
# (NEXT_PUBLIC_SITE_URL must be a public https:// origin for the webhook target.)

# === Sentry error monitoring (PF1.1, ADR-0072) ===
# The DSN is a write-only ingest key (safe to expose to the client). When unset,
# the Sentry SDK no-ops, so local/dev runs capture nothing. PII-safe by config
# (sendDefaultPii: false, ADR-0014).
NEXT_PUBLIC_SENTRY_DSN=
# Optional — only needed to upload source maps at build time (readable stack
# traces). Without these, errors still capture; the build plugin just skips upload.
# ALSO read by the admin metrics dashboard (ADR-0080) to pull open issues + error
# volume via the Sentry REST API. Optional SENTRY_URL overrides the host.
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_URL=https://sentry.io

# === Admin metrics — PostHog read API (ADR-0080) ===
# A personal API key + project id let the admin dashboard query active users + top
# events via HogQL. Distinct from the NEXT_PUBLIC_POSTHOG_KEY ingest key. Unset =
# the PostHog tiles show "unavailable" (the dashboard still works). Optional
# POSTHOG_API_HOST overrides the derived API host (e.g. https://eu.posthog.com).
# POSTHOG_PERSONAL_API_KEY=
# POSTHOG_PROJECT_ID=
# POSTHOG_API_HOST=

# === Engagement email — Resend (EE3, ADR-0081) ===
# Powers the weekly digest + return-nudge (both default OFF — turn on in
# /admin/email). Unset = email no-ops (isConfigured()=false); nothing sends.
# EMAIL_FROM must be a verified Resend sender, e.g. "MRT <hello@myresearchlab.app>".
RESEND_API_KEY=
EMAIL_FROM=
