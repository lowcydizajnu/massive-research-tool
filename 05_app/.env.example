# Public site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === Auth (Clerk) — wired in next iteration, ADR-0011 step 2 ===
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# === Database (Postgres via Drizzle) — wired in next iteration ===
DATABASE_URL=postgresql://user:password@localhost:5432/mrt_dev

# === Storage (R2 / S3 per ADR-0003) — wired when first asset feature lands ===
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# === Realtime (Liveblocks) — adapter stub only in MVP per ADR-0011 ===
LIVEBLOCKS_SECRET_KEY=

# === Background jobs (Inngest) — V1.5; keyless against `npx inngest-cli dev` locally ===
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# === Rate limiting (Upstash Redis) — V1.7.0 deploy, ADR-0016 / security review #9 ===
# Leave blank locally: the limiter falls back to an in-memory per-instance
# counter in dev/test (in production these are REQUIRED — a missing value is a
# fatal error, not a silent no-op). UPSTASH_IP_BUCKET_SALT salts the one-way
# coarse-IP hash used only as a limiter key (never persisted).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
UPSTASH_IP_BUCKET_SALT=

# === Secret encryption (V1.5, ADR-0005) — registry OAuth tokens at rest ===
# Base64-encoded 32-byte key, e.g. `openssl rand -base64 32`
TOKEN_ENCRYPTION_KEY=

# === OSF registry (V1.5, ADR-0005) — register an app at osf.io/settings/applications ===
# OSF_OAUTH_REDIRECT_URI must EXACTLY match the redirect registered on the OSF app
# AND the running host:port. Authorize/token URLs default to OSF's documented
# values; override if your app differs.
OSF_OAUTH_CLIENT_ID=
OSF_OAUTH_CLIENT_SECRET=
OSF_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/osf/callback
OSF_API_BASE=https://api.osf.io/v2
OSF_AUTHORIZE_URL=https://accounts.osf.io/oauth2/authorize
OSF_TOKEN_URL=https://accounts.osf.io/oauth2/token
OSF_SCOPES=osf.full_write
