# =========================================================================
# Project-root .gitignore
# Subfolders (notably 05_app/) have their own .gitignore for tool-specific patterns.
# =========================================================================

# Node / Next.js — anchor output dirs to repo root so they don't match route
# segments named out/dist/build (e.g. 05_app/app/(app)/studies/[id]/build/).
node_modules/
.next/
/out/
/dist/
/build/
*.tsbuildinfo
next-env.d.ts

# Environment files — never commit credentials
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Testing
coverage/
playwright-report/
test-results/
.playwright/

# Python (manifest scripts)
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/

# OS noise
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Editor noise
.vscode/
.idea/
.cursor/
*.swp
*.swo
*~

# Dropbox conflict files
*conflict*.md
*conflict*.txt
* (conflicted copy *
* (1).*
* (2).*

# Vercel
.vercel/

# Local caches
.cache/
.turbo/

# pnpm
.pnpm-store/
